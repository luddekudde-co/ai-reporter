generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  url         String   @unique
  summary     String?
  source      String
  publishedAt DateTime
  createdAt   DateTime @default(now())
}
