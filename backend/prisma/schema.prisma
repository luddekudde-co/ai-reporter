generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

model Article {
  id          Int          @id @default(autoincrement())
  title       String
  url         String       @unique
  summary     String?
  source      String
  publishedAt DateTime
  createdAt   DateTime     @default(now())
  category    String?
  impactLevel ImpactLevel?
  aiProcessed Boolean      @default(false)
}
